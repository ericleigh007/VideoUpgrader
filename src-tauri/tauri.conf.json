{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VideoUpgrader",
  "version": "0.1.0",
  "identifier": "com.ericl.videoupgrader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VideoUpgrader",
        "width": 1500,
        "height": 980,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
